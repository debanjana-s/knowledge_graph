    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/ctn#Depth_of_Invasion_8Edition@@1">
        <rdfs:label>≤5mm</rdfs:label>
        <rdfs:comment>Indicates less invasive lesion (T1)</rdfs:comment>
        <obo:IAO_0000115>Depth range for tumour invasion corresponding to less invasive lesions. It matches with T1 in the TNM classification system.</obo:IAO_0000115>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/ctn#Depth_of_Invasion_8Edition@@2">
        <rdfs:label>&gt;5mm and ≤10mm</rdfs:label>
        <obo:IAO_0000115>Depth range for tumour invasion corresponding to moderate depth of invasion cancer. It matches with T2 in the TNM classification system.</obo:IAO_0000115>
        <rdfs:comment>Indicates moderate depth (T2)</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/ctn#Depth_of_Invasion_8Edition@@3">
        <obo:IAO_0000115>Depth range for tumour invasion corresponding to deeply invasive cancers. It matches with T3 in the TNM classification system.</obo:IAO_0000115>
        <rdfs:comment>Indicates deeply invasive cancers (T3)</rdfs:comment>
        <rdfs:label>&gt;10mm</rdfs:label>
    </rdf:Description>
