    <!-- http://ontology.lst.tfo.upm.es/BD2D/tox#Xerostomia_AcTox -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/tox#Xerostomia_AcTox">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Toxicity_Data"/>
        <obo:IAO_0000115>CTCAE: Dry mouth.

G1: Symptomatic (e.g., dry or thick saliva) without significant dietary alteration; unstimulated saliva flow &gt;0.2 ml/min
G2: Moderate symptoms; oral intake alterations (e.g., copious water, other lubricants, diet limited to purees and/or soft, moist foods); unstimulated saliva 0.1 to 0.2 ml/min
G3: Inability to adequately aliment orally; tube feeding or TPN indicated; unstimulated saliva &lt;0.1 ml/min
G4-G5: Not reported</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/tox#Xerostomia_Toxicity_12 -->

