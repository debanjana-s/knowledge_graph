    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@2 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@2">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@3 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@3">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@4 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@4">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@5 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@5">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Extracapsular_Spread@@1 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Extracapsular_Spread@@1">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Extracapsular_Spread"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Extracapsular_Spread@@2 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Extracapsular_Spread@@2">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Extracapsular_Spread"/>
