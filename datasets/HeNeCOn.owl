    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Central_Necrosis@@2">
        <rdfs:label>Present</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Cutaneous_Invasion@@1">
        <rdfs:comment>The tumor has not invaded the skin</rdfs:comment>
