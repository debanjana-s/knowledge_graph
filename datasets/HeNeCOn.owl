        <obo:IAO_0000115 xml:lang="en">Surgery to remove lymph nodes and other tissues in the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Note_PoC_MbC -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Note_PoC_MbC">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">Description how the original plan of care was modified because of the complication. Expressed in a text note.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Plan_of_Care_Modified_by_Complication -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Plan_of_Care_Modified_by_Complication">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">A response that indicates whether the plan of care was modified due to complication.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Site_Neck_Dissection -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Site_Neck_Dissection">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">Position of the neck where the dissection is performed. It could be in the right side, left side or both (bilateral).</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Site_of_Surgery -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Site_of_Surgery">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">Position of the body where the surgery is performed. It could be the right or left side or in the midline.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Surgery_Reason -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Surgery_Reason">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">A response indicating the surgery’s aim, which could be a primary tumor or a recurrent tumor.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Surgical_Reconstruction -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Surgical_Reconstruction">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">Surgery that is done to reshape or rebuild (reconstruct) a part of the body changed by previous surgery.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Tracheostomy -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Tracheostomy">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">Surgery to create an opening (stoma) into the windpipe. The opening itself may also be called a tracheostomy.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Type_of_Complication -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Type_of_Complication">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">A response that indicates specific complication occurred during or after surgery.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Type_of_Surgery -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Type_of_Surgery">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">Type of surgery dependent on the involved structure in the head and neck region. The removed structure of the head and neck region is defined by the name of the performed surgery.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/surge#Undergone_Cancer_Surgery -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Undergone_Cancer_Surgery">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#surgical_treatment"/>
        <obo:IAO_0000115 xml:lang="en">A response indicating that an individual has been operated or not due to head and neck cancer.</obo:IAO_0000115>
    </owl:Class>
    


