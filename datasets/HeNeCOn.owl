    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#LR_CTV_Elective_Nodal_Volume -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#LR_CTV_Elective_Nodal_Volume">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Low Risk – Clinical Target Volume : Indicates whether (elective) lymph nodes on one side or both sides of the neck are irradiated.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Note_to_ToRT -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Note_to_ToRT">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Overall_Treatment_Time -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Overall_Treatment_Time">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Total duration of radiotherapy treatment. Number of days from the first day of radiotherapy treatment until the last day of radiotherapy treatment.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#RT_End_Date -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#RT_End_Date">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Date when radiotherapy treatment ends. Expressed as DD/MM/YYYY.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#RT_Fractionation_Referred_to_dose_per_fraction_HR_CTV -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#RT_Fractionation_Referred_to_dose_per_fraction_HR_CTV">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the dose per fraction to High Risk – Clinical Target Volume.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#RT_Start_Date -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#RT_Start_Date">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Date when radiotherapy treatment starts. Expressed as DD/MM/YYYY.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Radiotherapy_Treatment -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Radiotherapy_Treatment">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates if radiotherapy treatment is performed or not.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Reason_for_Discontinuation -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Reason_for_Discontinuation">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the reason for treatment (radiotherapy) termination. The termination could be when the planned treatment is finished, or when it is finished earlier, for example due to tumor progression or toxicity.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Setting -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Setting">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the configuration of the radiotherapy performed.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Target_Volume_RT -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Target_Volume_RT">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Time_from_Surgery_to_beginning_of_RT -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Time_from_Surgery_to_beginning_of_RT">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the number of weeks from surgery until the first day of radiotherapy.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Dose_HR_CTV -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Dose_HR_CTV">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>High risk CTV represents an area around the macroscopic disease (GTV) with high risk for microscopic spread, that is treated to the same dose as the GTV. Usually 5-10mm around primary tumor or positive lymph nodes.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Dose_IR_CTV -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Dose_IR_CTV">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the total dose of radiotherapy applied in Intermediate Risk – Clinical Target Volume. Expressed in Gy. 
IR-CTV is optional in case a third dose level for radiotherapy is used, for example when pathologic lymph nodes or a larger area around the HR-CTV receive a lower dose than the GTV. Should be 0 if no IR-CTV is used.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Dose_LR_CTV -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Dose_LR_CTV">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>LR-CTV represents an area with low risk for microscopic disease, treated with a lower dose than the GTV. For example elective nodal regions or a structure or compartment adjacent to the primary tumor.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Number_of_Fractions -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Number_of_Fractions">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the total number of fractions applied during the radiotherapy.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Number_of_Fractions_to_HR_CTV -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Number_of_Fractions_to_HR_CTV">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the total number of fractions to High Risk – Clinical Target Volume applied during the radiotherapy.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Treatment_Package -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Total_Treatment_Package">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the total time from surgery to completion of postoperative treatment, that is the amount of days between the day of surgery and the last day of postoperative radiotherapy. 
Shorter treatment package time is associated with improved tumor control and survival.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/radio#Type_of_RT -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/radio#Type_of_RT">
        <rdfs:subClassOf rdf:resource="http://neomark.owl#radiotherapy"/>
        <obo:IAO_0000115>Indicates the modality of the radiotherapy treatment.</obo:IAO_0000115>
    </owl:Class>
    


