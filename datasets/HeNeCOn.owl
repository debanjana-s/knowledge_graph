    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Basaloid_features -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Basaloid_features">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Morphological features of the tumors cells resembling those of  cells from the basal (deep) layers of a squamous epithelium.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Date_of_Pathology_Report -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Date_of_Pathology_Report">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The written and signed form of a pathological diagnosis.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The amount of keratin produced by a squamous cell carcinoma. It is an index of cell differentiation.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Depth_of_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Depth_of_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The value in millimeters (mm) of the depth of tissue invasion as measured perpendicularly from the line of the epithelial-stromal interface of the adjacent squamous mucosa to the deepest part of the tumor; it excludes any exophytic component.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Extracapsular_Spread -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Extracapsular_Spread">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>It indicates whether or not there is tumor spread beyond the lymphnode capsule.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Grade_at_Diagnosis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Grade_at_Diagnosis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>A measure of the tumor cell differentiation as compared to the normal reference tissue according to WHO criteria.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#HPV_DNA -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#HPV_DNA">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates whether or not there is presence of DNA of Human Papillomavirus in tumor tissue.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#HPV_Status -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#HPV_Status">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates whether or not Human papillomavirus (HPV) was detected in a tumor sample as assessed either directly by HPV DNA/RNA test or indirectly through p16ink4a immunostain.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#HPV_Testing -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#HPV_Testing">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates which method was used to assess the presence of Human Papillomavirus (HPV) DNA or RNA transcripts in a tumor sample. Accepted methods are: polymerase chain reaction (PCR), reverse transcription- polymerase chain reaction (RT-PCR), and  in situ hybridization (ISH).</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_I -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_I">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the left side of level I of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_II -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_II">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the left side of level II of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_III -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_III">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the left side of level III of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_IV -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_IV">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the left side of level IV of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_V -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Left_Side_Level_V">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the left side of level V of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Level_of_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Level_of_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The anatomical level of tumor invasion in adjacent tissues.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Lympho_Plasmacytic_Reaction -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Lympho_Plasmacytic_Reaction">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The degree of the lympho-plasmacellular reaction as assessed mainly at the tumor-stroma interface; this is a favourable prognostic variable. The possible values can be: none, mild, moderate, marked or not evaluable.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Lympho_Vascular_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Lympho_Vascular_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The presence of tumor cells within small vessels, either lymphatic or blood vessels.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Nuclear_Pleomorphism -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Nuclear_Pleomorphism">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The degree of variation in size, form or chromatin texture, shown by the nuclei of tumor cells.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Pathology_Case_Number -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Pathology_Case_Number">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The number of the pathology report that refers to the tissue specimen used for the evaluation of the pathological data.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Pattern_of_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Pattern_of_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The pattern of growth of the tumor at the front of invasion. The possible categories can be: cohesive, focal non cohesive, extensive non cohesive or not evaluable. The worst pattern of invasion is a validated outcome for oral SCC patients.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Perineural_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Perineural_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The presence of tumor cells within the perineural layer of a nerve, either named (should be specified) or unnamed.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_I -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_I">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the right side of level I of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_II -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_II">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the right side of level II of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_III -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_III">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the right side of level III of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_IV -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_IV">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the right side of level IV of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_V -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Right_Side_Level_V">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the number of involved metastatic lymph nodes on the right side of level V of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Site -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Site">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Anatomical localization of the tumor according to the ICD10-CM classification.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Surgical_Margins -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Surgical_Margins">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates whether cancer cells are present or not at the surgical edge of the resection specimen; it does not apply to incisional biopsies.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pN_7Edition -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pN_7Edition">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The TNM staging system is a system to describe the amount and spread of cancer in a patient’s body, using TNM. T describes the size of the tumor and any spread of cancer into nearby tissue; N describes spread of cancer to nearby lymph nodes; and M describes metastasis (spread of cancer to other parts of the body). This system was created and is updated by the American Joint Committee on Cancer (AJCC) and the International Union Against Cancer (UICC). The TNM staging system is used to describe most types of cancer. Also called AJCC staging system.
This refer to the 7th edition published in 2009 and the effective dates for cancer diagnoses are 2010-2016.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pN_8Edition_OralCavity_Oropharynx_p16Negative_Hypopharynx_Larynx -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pN_8Edition_OralCavity_Oropharynx_p16Negative_Hypopharynx_Larynx">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The TNM staging system is a system to describe the amount and spread of cancer in a patient’s body, using TNM. T describes the size of the tumor and any spread of cancer into nearby tissue; N describes spread of cancer to nearby lymph nodes; and M describes metastasis (spread of cancer to other parts of the body). This system was created and is updated by the American Joint Committee on Cancer (AJCC) and the International Union Against Cancer (UICC). The TNM staging system is used to describe most types of cancer. Also called AJCC staging system.
This refer to the 8th edition published in 2016 and the effective dates for cancer diagnoses are from 2017. This staging is for the following tumor regions: Oral Cavity, Oropharynx (p16-Negative), Hypopharynx and Larynx.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pN_8Edition_Oropharynx_p16Positive -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pN_8Edition_Oropharynx_p16Positive">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The TNM staging system is a system to describe the amount and spread of cancer in a patient’s body, using TNM. T describes the size of the tumor and any spread of cancer into nearby tissue; N describes spread of cancer to nearby lymph nodes; and M describes metastasis (spread of cancer to other parts of the body). This system was created and is updated by the American Joint Committee on Cancer (AJCC) and the International Union Against Cancer (UICC). The TNM staging system is used to describe most types of cancer. Also called AJCC staging system.
This refer to the 8th edition published in 2016 and the effective dates for cancer diagnoses are from 2017. This staging is for the following tumor regions: Oropharynx (p16-Positive).</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pT_7Edition -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pT_7Edition">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The TNM staging system is a system to describe the amount and spread of cancer in a patient’s body, using TNM. T describes the size of the tumor and any spread of cancer into nearby tissue; N describes spread of cancer to nearby lymph nodes; and M describes metastasis (spread of cancer to other parts of the body). This system was created and is updated by the American Joint Committee on Cancer (AJCC) and the International Union Against Cancer (UICC). The TNM staging system is used to describe most types of cancer. Also called AJCC staging system.
This refer to the 7th edition published in 2009 and the effective dates for cancer diagnoses are 2010-2016.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pT_8Edition_OralCavity_Oropharynx_p16Negative_Hypopharynx_Larynx -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pT_8Edition_OralCavity_Oropharynx_p16Negative_Hypopharynx_Larynx">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The TNM staging system is a system to describe the amount and spread of cancer in a patient’s body, using TNM. T describes the size of the tumor and any spread of cancer into nearby tissue; N describes spread of cancer to nearby lymph nodes; and M describes metastasis (spread of cancer to other parts of the body). This system was created and is updated by the American Joint Committee on Cancer (AJCC) and the International Union Against Cancer (UICC). The TNM staging system is used to describe most types of cancer. Also called AJCC staging system.
This refer to the 8th edition published in 2016 and the effective dates for cancer diagnoses are from 2017. This staging is for the following tumor regions: Oral Cavity, Oropharynx (p16-Negative), Hypopharynx and Larynx.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pT_8Edition_Oropharynx_p16Positive -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#TNM_pT_8Edition_Oropharynx_p16Positive">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The TNM staging system is a system to describe the amount and spread of cancer in a patient’s body, using TNM. T describes the size of the tumor and any spread of cancer into nearby tissue; N describes spread of cancer to nearby lymph nodes; and M describes metastasis (spread of cancer to other parts of the body). This system was created and is updated by the American Joint Committee on Cancer (AJCC) and the International Union Against Cancer (UICC). The TNM staging system is used to describe most types of cancer. Also called AJCC staging system.
This refer to the 8th edition published in 2016 and the effective dates for cancer diagnoses are from 2017. This staging is for the following tumor regions: Oropharynx (p16-Positive).</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Tissue_Type -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Tissue_Type">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The type of specimen used for diagnosis based on the procedure performed to remove the tissue from the body. The possible options can be: resection specimen (wide surgical resection performed with intent of cure) and biopsy (excisional or incisional sample obtained for diagnostic purposes).</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Tumor_Depth_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Tumor_Depth_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Describes the degree tumor depth invasion only when oral cavity cancer is diagnosed. Indicates if the tumor depth invasion is less than 5mm, between 5mm and 10mm or more than 10mm.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Tumor_Maximum_Diameter -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Tumor_Maximum_Diameter">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the value in millimeters (mm) of maximum diameter of tumor.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Tumor_Thickness -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Tumor_Thickness">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>The value in millimeters (mm) of tumor thickness; it includes any exophytic component.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Type_of_Test -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Type_of_Test">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Describes in detail the polymerase chain reaction (PCR) method used for HPV DNA or RNA detection.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#p16ink4a_stain -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#p16ink4a_stain">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Immunoreactivity to p16ink4a protein in tumor cells; strong stain in &gt;70% of tumor cells correlates with the presence of cancerogenic HPV types. This applies only to oro-pharyngeal tumors.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#p53_stain -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#p53_stain">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Immunoreactivity to p53 protein, either diffuse overexpression or complete loss of expression correlate with mutated status.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#p53_stain_percentage -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#p53_stain_percentage">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Pathology_Data"/>
        <obo:IAO_0000115>Indicates the percentage of immunoreactive tumor cells on the total of tumor cells to p53 in a tissue sample.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Basaloid_features@@1 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Basaloid_features@@1">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Basaloid_features"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Basaloid_features@@2 -->

