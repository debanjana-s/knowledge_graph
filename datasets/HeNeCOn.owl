        <rdfs:label>Skin</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/ctn#Tissue_Invasion_ExtraNodalExtension_to@@2">
        <rdfs:label>Muscle</rdfs:label>
    </rdf:Description>
