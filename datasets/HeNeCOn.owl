    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Complication@@1">
        <rdfs:label>No</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Complication@@2">
        <rdfs:label>Yes</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Complication_Action_Taken@@1">
        <obo:IAO_0000115>A procedure to remove or repair a part of the body or to find out whether disease is present. An operation or in case of action for complications, surgery that is perfomed to improve the situation or recover after a surgical complication.</obo:IAO_0000115>
        <rdfs:label>Further surgery</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Complication_Action_Taken@@2">
        <rdfs:label>Nothing waiting and observation</rdfs:label>
        <obo:IAO_0000115>Closely watching a patient’s condition but not giving treatment unless symptoms appear or change. Watchful waiting is sometimes used in conditions that progress slowly. It is also used when the risks of treatment are greater than the possible benefits. During watchful waiting, patients may be given certain tests and exams.</obo:IAO_0000115>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Complication_Action_Taken@@3">
        <rdfs:label>Hyperbaric radiotherapy</rdfs:label>
        <obo:IAO_0000115>Medical treatment in which an ambient preassure greater than sea level atmospheric pressure is used to improve e.g. wound healing.</obo:IAO_0000115>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/surge#Complication_Action_Taken@@4">
        <rdfs:label>Other</rdfs:label>
    </rdf:Description>
