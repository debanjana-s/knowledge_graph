        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Basaloid_features"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@1 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation@@1">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/patho#Degree_of_Cell_Keratinisation"/>
