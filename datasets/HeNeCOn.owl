    <!-- http://ontology.lst.tfo.upm.es/BD2D/follow#Primary_Cause_of_Death -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/follow#Primary_Cause_of_Death">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Follow_Up"/>
        <obo:IAO_0000115>Main reason of patient death.

