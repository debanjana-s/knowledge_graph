    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Additional_precancerous_lesion_1 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Additional_precancerous_lesion_1">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>A premalignant pathologic process that affects the anatomic structures of the head and neck. Representative examples include oral leukoplakia and leukoplakia of the vocal cords.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Additional_precancerous_lesion_2 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Additional_precancerous_lesion_2">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>A premalignant pathologic process that affects the anatomic structures of the head and neck. Representative examples include oral leukoplakia and leukoplakia of the vocal cords.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Alcohol_at_Time_of_Diagnosis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Alcohol_at_Time_of_Diagnosis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Family_History_of_Malignancies -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Family_History_of_Malignancies">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>A clinical history in which there is a diagnosis of cancer in a blood relative.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#History_of_Alcohol_Dependence -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#History_of_Alcohol_Dependence">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>Alcohol dependence is a chronic disease in which a person craves drinks that contain alcohol and is unable to control his or her drinking. A person with this disease also needs to drink greater amounts to get the same effect and has withdrawal symptoms after stopping alcohol use. Alcohol dependence affects physical and mental health, and can cause problems with family, friends, and work. Regular heavy alcohol intake increases the risk of several types of cancer. Also called alcoholism.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Location_of_additional_precancerous_lesion_1 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Location_of_additional_precancerous_lesion_1">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>Location of the additional precancerous lesion based on the ICD-10 code.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Location_of_additional_precancerous_lesion_2 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Location_of_additional_precancerous_lesion_2">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>Location of the additional precancerous lesion based on the ICD-10 code.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Notes_risk -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Notes_risk">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>Additional notes for Risk section.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Number_of_Alcohol_Units_per_Day -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Number_of_Alcohol_Units_per_Day">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>Number of alcohol units consumed in 1 day based on the unit calculator (https://www.alcoholconcern.org.uk/unit-calculator)

Type of drink ---------- Number of alcohol units
Standard glass of wine ---------- 2.3 units
Small Glass of Wine ---------- 1.3 units
Large glass of wine ---------- 3.3 units
Pint of strong lager or ale ---------- 3.0 units
Alcopop ---------- 1.4 units
Shot of whiskey ---------- 1.0 units
Pint of lager ---------- 2.0 units
Bottle of super strength lager or ale ---------- 3.0 units
Can of super strength lager or ale ---------- 3.5 units</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Oral_Hygiene -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Oral_Hygiene">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>The practice of keeping the mouth, teeth, and gums clean and healthy to prevent disease, as by regular brushing and flossing and visits to a dentist.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Pack_Years -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Pack_Years">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>A way to measure the amount a person has smoked over a long period of time. It is calculated by multiplying the number of packs of cigarettes smoked per day by the number of years the person has smoked. For example, 1 pack year is equal to smoking 1 pack (20 cigarettes) per day for 1 year, or 2 packs per day for half a year, and so on.

Number of pack-years = (packs smoked per day) × (years as a smoker)
or
Number of pack-years = (number of cigarettes smoked per day/20) × number of years smoked. (1 pack has 20 cigarettes in some countries)</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Packs_Smoked_per_Day -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Packs_Smoked_per_Day">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>Number of packs of cigarettes or cigars consumed in 1 day.

1pack = numbers per Day/20 per cigarettes or /4 per cigars</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Virtual_Patient"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Smoker_at_Time_of_Diagnosis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Smoker_at_Time_of_Diagnosis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>An indication of a person&apos;s current tobacco and nicotine consumption as well as some indication of smoking history.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Smoking_Habits -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Smoking_Habits">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>Indicates any of the habits associated with smoking.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/risk#Years_as_a_Smoker -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/risk#Years_as_a_Smoker">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/risk#Risk_Factors"/>
        <obo:IAO_0000115>Number of total years an individual smoked or currently smokes cigarettes.</obo:IAO_0000115>
