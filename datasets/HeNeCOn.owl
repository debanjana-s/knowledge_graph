    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Buccal_Fat_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Buccal_Fat_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the buccal fat pad.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Carotid_Infiltration -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Carotid_Infiltration">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor from the involved lymph node has infiltrated the carotid  artery.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Case_Number_Image_ID -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Case_Number_Image_ID">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates the identifier for a diagnostic imaging study.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Central_Necrosis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Central_Necrosis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Presence or absence of death of the central part of a tissue or organ.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Cutaneous_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Cutaneous_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the skin.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Cutaneous_Invasion_Skin -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Cutaneous_Invasion_Skin">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor from the involved lymph node has invaded the skin.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Date_of_Analysis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Date_of_Analysis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Date on which an imaging procedure was performed for a patient. Expressed as DD/MM/YYYY.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#ENS_Irregular_Margin_Edges -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#ENS_Irregular_Margin_Edges">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>It refers to the alteration of the surrounding fat/irregular margins edges in the lymph node.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Extension_Site -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Extension_Site">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Body site where the tumor spreads. The body site is determined according to the ICD10-CM classification.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Extra_Nodal_Spreading -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Extra_Nodal_Spreading">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Presence of tumor extension beyond the lymph node capsule.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Extra_Tumor_Spreading -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Extra_Tumor_Spreading">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Presence of tumor extension beyond the primary boundaries of an organ.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Extrinsic_Tongue_Musculature_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Extrinsic_Tongue_Musculature_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the extrinsic muscles of the tongue, which all arise outside the tongue, which is in comparison to the intrinsic muscles of the tongue which are entirely within the tongue with no external attachments. The extrinsic tongue muscles are genioglossus muscle, hyoglossus muscle, styloglossus muscle and palatoglossus muscle.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Floor_of_the_Mouth_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Floor_of_the_Mouth_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the floor of the mouth, that is the area of the mouth under the ventral surface of the tongue.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Image_Contrast -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Image_Contrast">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Characteristic of imaging procedure. The contrast agent can be used or not to enhance the image.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Image_Site -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Image_Site">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Tumor localization according to the ICD10-CM classification.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Image_Type -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Image_Type">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates the diagnostic imaging type used during the diagnosis procedure.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Internal_Carotid_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Internal_Carotid_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the internal carotid.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Bone_Infiltration -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Bone_Infiltration">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor from the involved lymph node has infiltrated the bone, which could be any bone adjacent to the involved lymph node.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Contrast_Take_up_Rate -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Contrast_Take_up_Rate">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Amount of contrast enhancement in lymph nodes, based on the difference between contrast and non contrast imaging.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Major_Axis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Major_Axis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>The largest cross sectional diameter of an involved lymph node.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Minor_Axis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Minor_Axis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>The smalles cross sectional diameter of an involved lymph node.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Necrosis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Necrosis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Presence or not of necrosis within a lymph node.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Side -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Side">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Position of the body where the lymph node is located. It could be the right or left side or in the midline.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Site -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Site">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Localization of involved lymph nodes based on the lymph node levels of the neck.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Volume -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Lymph_Volume">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>The size of an involved lymph node, measured in mm^3.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Masticator_Space_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Masticator_Space_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the masticator space, which is the potential space containing the pterygoid and masseter muscles.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Maxillary_Sinus_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Maxillary_Sinus_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the maxillary sinus, which is the pyramidal-shaped, thin-walled, air-filled cavity located in the maxilla.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Number_of_Lymph_Nodes_Involved -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Number_of_Lymph_Nodes_Involved">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Reports the presence and the number of involved lymph nodes.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Orbital_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Orbital_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the orbit, which is the bony cavity of the skull which contains the eye, anterior portion of the optic nerve, ocular muscles and ocular adnexa.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Oropharynx_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Oropharynx_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the oropharynx, which is the part of the pharynx between the soft palate and the upper portion of the epiglottis.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Parapharyngeal_Space_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Parapharyngeal_Space_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the parapharyngeal space. The parapharyngeal space is the potential space of the neck, which is bounded superiorly by the base of the skull, inferiorly by the greater cornu of the hyoid bone, anteriorly by the investing fascia of the deep cervical fascia covering the medial pterygoid muscle, posteriorly by the prevertebral layer of the deep cervical fascia, medially by the middle (pretracheal) layer of the deep cervical fascia, and laterally by the investing fascia of the deep cervical fascia covering the deep lobe of the parotid.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Perineural_Infiltration -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Perineural_Infiltration">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the nerve fibers or is around a nerve or group of nerves.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Periosteal_Infiltration -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Periosteal_Infiltration">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has infiltrated the periosteum.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Pterygo_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Pterygo_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the pterygoid muscle.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Pterygo_Palatine_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Pterygo_Palatine_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the pterygopalatine fossa.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Retromolar_Area_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Retromolar_Area_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the retromolar trigone, which is the triangular-shaped area of mucosa located posterior the last mandibular molar tooth.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Selected_Images -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Selected_Images">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>A number of images selected by the radiologist to use for analysis.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Shape_Deviation -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Shape_Deviation">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Side_Relative_to_Tumour -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Side_Relative_to_Tumour">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Position of the involved lymph nodes in relation to the primary tumor.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Skull_Base_Invasion -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Skull_Base_Invasion">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if tumor has invaded the base of skull, which is the portion of the skull that forms the floor on which the brain lies.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Spread_Across_Midline -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Spread_Across_Midline">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>A response that indicates whether the tumor spreading has occurred through the midline of body.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Stage_Grouping -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Stage_Grouping">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>An assessment based on the combined evaluation of the patient&apos;s T stage, M stage, and N stage, as well as prognostic parameters for specific cancers. See TNM staging system for each anatomic (sub)site.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#TNM_Radiological_M -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#TNM_Radiological_M">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Presence or absence of distant tumor spreading based on diagnostic imaging, defined for each anatomic (sub)site in the TNM staging system.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#TNM_Radiological_N -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#TNM_Radiological_N">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Extension of nodal tumor involvement based on diagnostic imaging, defined for each anatomic (sub)site in the TNM staging system.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#TNM_Radiological_T -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#TNM_Radiological_T">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Extension of primary tumor based on diagnostic imaging, defined for each anatomic (sub)site in the TNM staging system.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Bone_Infiltration -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Bone_Infiltration">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Indicates if the primary tumor has infiltrated the bone , which could be any bone adjacent to the primary tumor. For head and neck cancers most important bones for infiltration are the mandible, maxilla and skull base.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Contrast_Take_up_Rate -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Contrast_Take_up_Rate">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Amount of contrast enhancement, based on the difference between contrast and non contrast imaging.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Major_Axis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Major_Axis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>The largest cross sectional diameter of a primary tumor.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Minor_Axis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Minor_Axis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>The smalles cross sectional diameter of a primary tumor.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Necrosis -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Necrosis">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Presence or not of necrosis within a tumor.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Side -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Side">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <rdfs:comment>Position of the body where the tumor is located. It could be the right or left side or in the midline.</rdfs:comment>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Site -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Site">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Tumor localization according to the ICD10-CM classification.
ICD10-CM is a classification of neoplasms, whether are functionally active or not. The classification is primarily by site (topography), with broad groupings for behavior, malignant, in situ, benign, etc.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Thickness_Staging -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Thickness_Staging">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>Classification of primary tumor thickness.</obo:IAO_0000115>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Volume -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/img#Tumor_Volume">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Imaging_Data"/>
        <obo:IAO_0000115>The size of a cancer measured by the amount of space taken up by the primary tumor, measured in mm^3.
The volume is automatically calculated based on tumor contouring.</obo:IAO_0000115>
    </owl:Class>
    


