    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/chemo#Type_of_CT@@1">
        <rdfs:label>Induction</rdfs:label>
        <obo:IAO_0000115>Chemotherapy strategy in which drugs are administered before a loco-regional treatment (either surgery or radiotherapy or chemo-radiotherapy).</obo:IAO_0000115>
        <rdfs:comment>Administered before a loco-regional treatment (either surgery or radiotherapy or chemo-radiotherapy)</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/chemo#Type_of_CT@@2">
        <obo:IAO_0000115>Chemotherapy strategy in which drugs are administered with radiotherapy.</obo:IAO_0000115>
        <rdfs:label>Concomitant</rdfs:label>
        <rdfs:comment>Administered with radiotherapy</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/chemo#Type_of_CT@@3">
        <rdfs:label>Adjuvant</rdfs:label>
        <obo:IAO_0000115>Chemotherapy strategy in which drugs are administered after a loco-regional treatment (either surgery or radiotherapy or chemo-radiotherapy).</obo:IAO_0000115>
        <rdfs:comment>Administered after a loco-regional treatment (either surgery or radiotherapy or chemo-radiotherapy)</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@1">
        <rdfs:comment>Normal healthy patient</rdfs:comment>
        <obo:IAO_0000115>ASA category that includes normal healthy patients.</obo:IAO_0000115>
        <rdfs:label>I</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@2">
        <rdfs:comment>Patient with mild systemic disease</rdfs:comment>
        <rdfs:label>II</rdfs:label>
        <obo:IAO_0000115>ASA category that includes patients with mild systemic disease.</obo:IAO_0000115>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@3">
        <rdfs:comment>Patient with severe systemic disease</rdfs:comment>
        <rdfs:label>III</rdfs:label>
        <obo:IAO_0000115>ASA category that includes patients with severe systemic disease.</obo:IAO_0000115>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@4">
        <obo:IAO_0000115>ASA category that includes patients with severe systemic disease that is a constant threat to life.</obo:IAO_0000115>
        <rdfs:comment>Patient with severe systemic disease that is a constant threat to life</rdfs:comment>
        <rdfs:label>IV</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@5">
        <rdfs:label>V</rdfs:label>
        <obo:IAO_0000115>ASA category that includes moribund patients who are not expected to survive without the operation.</obo:IAO_0000115>
        <rdfs:comment>Moribund patient who is not expected to survive without the operation</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@6">
        <rdfs:label>Not Available</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ECOG_Performance_Status@@1">
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</rdfs:label>
        <obo:IAO_0000115>Grade of the ECOG Performance Status that indicates that the patient is fully active and able to carry on all pre-disease performance without restriction.</obo:IAO_0000115>
        <rdfs:comment>Fully active, able to carry on all pre-disease performance without restriction</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ECOG_Performance_Status@@2">
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</rdfs:label>
        <obo:IAO_0000115>Grade of the ECOG Performance Status that indicates that the patient is restricted in physically strenuous activity but ambulatory and able to carry out work of a light or sedentary nature, e.g, light house work, office work.</obo:IAO_0000115>
        <rdfs:comment>Restricted in physically strenuous activity but ambulatory and able to carry out work of a light or sedentary nature, e.g., light house work, office work</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ECOG_Performance_Status@@3">
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</rdfs:label>
        <obo:IAO_0000115>Grade of the ECOG Performance Status that indicates that the patient is ambulatory and capable of all selfcare but unable to carry out any work activities and that he/she is up and about more than 50% of waking hours.</obo:IAO_0000115>
