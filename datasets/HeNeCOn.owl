    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@4">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@5 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@5">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA"/>
    </owl:Class>
    


    <!-- http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@6 -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/clinical#ASA@@6">
