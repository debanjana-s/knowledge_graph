    <!-- http://ontology.lst.tfo.upm.es/BD2D/follow#Follow_Up_Period -->

    <owl:Class rdf:about="http://ontology.lst.tfo.upm.es/BD2D/follow#Follow_Up_Period">
        <rdfs:subClassOf rdf:resource="http://ontology.lst.tfo.upm.es/BD2D#Follow_Up"/>
